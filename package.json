{
  "name": "@ai-caller/root",
  "private": true,
  "scripts": {
    "postinstall": "lefthook install",
    "dev": "turbo dev --parallel",
    "fclean": "rm -rf node_modules apps/*/node_modules apps/*/.turbo apps/*/build apps/*/.react-router .turbo bun.lock",
    "up": "docker compose --env-file ./apps/api/.env up",
    "down": "docker compose --env-file ./apps/api/.env down",
    "http": "ngrok --config ngrok.yml http --url=light-grackle-eternal.ngrok-free.app 5678",
    "mcp:debug": "bunx @modelcontextprotocol/inspector --config ./mcp-inspector.json --server mcp:debug",
    "check-types": "turbo check-types --parallel --ui stream",
    "build": "turbo build --parallel --ui stream",
    "check": "biome check --write --unsafe"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "turbo": "2.8.17"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "lefthook": "2.1.4",
    "@biomejs/biome": "2.4.7"
  }
}
