# ENVIRONMENT (LOCAL | DEV | PROD — in PROD, .env is not loaded)
ENVIRONMENT=LOCAL

# SERVER
PORT=
CLIENT_URL=

# DATABASE (needed by docker-compose before Infisical is available)
DATABASE_PASSWORD=
DATABASE_USERNAME=
DATABASE_NAME=
DATABASE_PORT=
DATABASE_URL=

# INFISICAL (optional — without these, secrets are read from process.env)
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_SITE_URL=
INFISICAL_ENVIRONMENT=
INFISICAL_PORT=
INFISICAL_ENCRYPTION_KEY=
INFISICAL_AUTH_SECRET=

# N8N
N8N_PORT=
N8N_URL=

# CONFIG
ROOM_CALL_DURATION_MINUTE=

# TWILIO (optional — telephony is opt-in, move to Infisical when configured)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_BASE_URL=

# SECRETS (move to Infisical when configured, keep here as fallback)
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
N8N_API_KEY=
ROOT_EMAIL=
