{
  "name": "@ai-caller/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --minify --splitting",
    "start": "NODE_ENV=production bun dist/index.js",
    "check-types": "tsc --noEmit",
    "db:re-migrate": "rm -rf prisma/migrations && bunx prisma migrate reset --force && bunx prisma migrate dev -n default && bunx prisma generate",
    "studio": "bun run prisma studio",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:integration:db": "bun test tests/integration/db",
    "test:integration:http": "bun test tests/integration/http",
    "test:integration:external": "bun test tests/integration/external",
    "n8n": "bun scripts/n8n.ts"
  },
  "exports": {
    "./types": "./src/types.ts",
    "./openapi": "./dist/openapi.d.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash-es": "4.17.12"
  },
  "dependencies": {
    "@ai-caller/shared": "workspace:*",
    "@hono/zod-openapi": "1.2.2",
    "@infisical/sdk": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@scalar/hono-api-reference": "0.10.3",
    "better-auth": "1.5.5",
    "cron": "4.4.0",
    "dayjs": "1.11.20",
    "dotenv": "17.3.1",
    "dotenv-expand": "12.0.3",
    "handlebars": "4.7.8",
    "hono": "4.12.8",
    "inversify": "8.1.0",
    "lodash-es": "4.17.23",
    "openapi-typescript": "7.13.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prisma": "7.5.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "twilio": "^5.13.0",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  }
}
